rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Products ──────────────────────────────────────────────────────────────
    // Public read so customers can browse the shop.
    // Only authenticated employees (admin claim) can write.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    // Anyone can place an order (anonymous checkout).
    // Customers can read their own orders.
    // Employees can read, update, and delete any order.
    match /orders/{orderId} {
      allow create: if true;
      allow get, update: if request.auth != null && (
        request.auth.token.admin == true ||
        resource.data.userId == request.auth.uid
      );
      // Public order tracking: limit(1) query by orderNumber only — can't dump the collection
      allow list: if request.auth != null || request.query.limit <= 1;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Purchases ─────────────────────────────────────────────────────────────
    // Internal — employees only.
    match /purchases/{purchaseId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Suppliers ─────────────────────────────────────────────────────────────
    match /suppliers/{supplierId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Settlements ───────────────────────────────────────────────────────────
    match /settlements/{settlementId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Promotions ────────────────────────────────────────────────────────────
    // Customers validate promo codes at checkout, so public read is needed.
    // Only employees can create or modify promotions.
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Loyalty points ────────────────────────────────────────────────────────
    // Each user can read and write only their own loyalty document.
    match /loyalty/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Order sequence counters ───────────────────────────────────────────────
    // Anyone can read; counter can only be incremented by exactly 1 per write.
    match /counters/{counterId} {
      allow read: if true;
      allow create: if request.resource.data.count == 1;
      allow update: if request.resource.data.count == resource.data.count + 1;
    }
  }
}
